{
  "manifest_version": 3,
  "name": "Operix Companion",
  "version": "0.1.0",
  "description": "Keep your running Operix tasks, checklists, and related guides docked to the edge of your screen while you work.",
  "permissions": ["storage", "alarms", "identity"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": { "service_worker": "src/background.js", "type": "module" },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Operix Companion",
    "default_icon": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" }
  },
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" },
  "options_ui": { "page": "src/options.html", "open_in_tab": true },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
