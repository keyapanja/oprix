// Oprix — Phase 1 data model
// PostgreSQL + Prisma. Multi-tenant: every tenant-owned row carries companyId.
// Money is stored in integer minor units (paise). Timestamps are UTC.
// See docs/REFERENCE.md § 2 (Architecture) for the reasoning behind these choices.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — app runtime
  directUrl = env("DIRECT_URL") // direct connection — migrations
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  HR_MANAGER
  PROJECT_MANAGER
  TEAM_LEAD
  EMPLOYEE
  CLIENT
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum ProbationStatus {
  ON_PROBATION
  CONFIRMED
}

enum EmployeeDocType {
  OFFER_LETTER
  NDA
  ID_PROOF
  CERTIFICATE
  OTHER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectType {
  ONE_TIME
  RECURRING
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  HOLD // paused by the assigner/assignee; excluded from deadline/overdue pressure until resumed
  REVIEW // submitted by the worker, waiting for the creator's review
  REDO // creator requested changes; back with the worker
  CLIENT_REVIEW // approved internally, waiting for client review
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TimerStatus {
  RUNNING
  PAUSED
}

enum AttendanceType {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum ApprovalStatus {
  PENDING
  MANAGER_APPROVED
  HR_APPROVED
  REJECTED
  APPROVED // generic terminal-approved (e.g. timesheet single-step)
}

enum LeavePaidType {
  PAID
  UNPAID
}

enum AllowancePeriod {
  MONTH
  YEAR
}

enum RequestKind {
  LEAVE
  WFH
}

enum PayrollRunStatus {
  DRAFT
  LOCKED
  PAID
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum DeliverableStatus {
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
}

// ============================================================
// TENANT + ORGANIZATION (Module 1)
// ============================================================

model Company {
  id                 String   @id @default(cuid())
  name               String
  logoKey            String?
  logoUrl            String? // logo image URL — real uploads land in Phase 2 file storage
  address            String?
  timezone           String   @default("Asia/Kolkata")
  currency           String   @default("INR")
  businessType       String?
  tagline            String?  // short descriptor shown in the sidebar / branding
  website            String?
  email              String?
  phone              String?
  employeeCodePrefix String   @default("EMP")
  multiLocation      Boolean  @default(false)
  // Payroll: which statutory deductions this company is registered for. When a
  // component is off, it's skipped at payroll time (e.g. small firms with no
  // PF/ESI registration → Basic can be the full net pay).
  pfEnabled          Boolean  @default(true)
  esiEnabled         Boolean  @default(true)
  // Remind everyone the day before a holiday / announcement.
  eventReminderEnabled Boolean @default(false)
  eventReminderTime    String  @default("09:00") // HH:MM in the company timezone
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users            User[]
  departments      Department[]
  services         Service[]
  designations     Designation[]
  workShifts       WorkShift[]
  locations        Location[]
  probationPeriods ProbationPeriod[]
  rolePermissions  RolePermission[]
  employees        Employee[]
  projects         Project[]
  clients          Client[]
  leaveTypes       LeaveType[]
  holidays         Holiday[]
  announcements    Announcement[]
  payrollRuns      PayrollRun[]
  kbCategories     KbCategory[]
  ptSlabs          ProfessionalTaxSlab[]
}

// Company holidays — shown to every employee on the calendar.
model Holiday {
  id        String   @id @default(cuid())
  companyId String
  date      DateTime @db.Date
  name      String
  reminderSentAt DateTime? // day-before reminder fan-out guard
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, date])
  @@index([companyId])
}

// Company announcements / updates surfaced on the shared calendar.
model Announcement {
  id        String   @id @default(cuid())
  companyId String
  authorId  String? // userId who posted it (null = legacy)
  title     String
  body      String?
  date      DateTime @db.Date
  reminderSentAt DateTime? // day-before reminder fan-out guard
  createdAt DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id])
  attachments Attachment[]

  @@index([companyId, date])
}

// Work locations / sites. When Company.multiLocation is false, exactly one is
// used and auto-assigned; when true, employees pick one.
model Location {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

// Saved probation durations (e.g. 3 / 6 months) to pick from on the employee form.
model ProbationPeriod {
  id        String @id @default(cuid())
  companyId String
  months    Int

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, months])
  @@index([companyId])
}

// Dynamic role permissions. Presence of a row = that role is granted that
// capability for the company. Absence (when the company has any rows) = denied.
// Super Admin is always full and never stored here.
model RolePermission {
  id        String @id @default(cuid())
  companyId String
  role      Role
  action    String

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, role, action])
  @@index([companyId, role])
}

model Department {
  id        String   @id @default(cuid())
  companyId String
  name      String
  headId    String?  // Employee who heads the department
  createdAt DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id])
  head         Employee?     @relation("DeptHead", fields: [headId], references: [id])
  services     Service[]
  designations Designation[]
  employees    Employee[]
  kbArticles   KbArticle[]

  @@unique([companyId, name])
  @@index([companyId])
}

// Service lines the company offers (Web Dev, Content, Paid Ads…). Formerly "Team".
// A Service is either a CATEGORY (parentId = null) or a SUB-CATEGORY (parentId
// set). Projects link to categories; tasks pick a sub-category. The department
// lives on the category and sub-categories inherit it (used for task-assignee
// filtering and TEAM visibility).
model Service {
  id           String   @id @default(cuid())
  companyId    String
  departmentId String?
  parentId     String? // null = category (top-level); set = sub-category
  name         String
  createdAt    DateTime @default(now())

  company          Company                @relation(fields: [companyId], references: [id])
  department       Department?            @relation(fields: [departmentId], references: [id])
  parent           Service?               @relation("ServiceTree", fields: [parentId], references: [id])
  children         Service[]              @relation("ServiceTree")
  employees        Employee[]
  projectLinks     ProjectService[]
  tasks            Task[]
  checklistTemplate ServiceChecklistItem[]
  kbArticles       KbArticle[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentId])
}

// Default checklist a service seeds onto every task created under it.
model ServiceChecklistItem {
  id         String @id @default(cuid())
  serviceId  String
  text       String
  orderIndex Int    @default(0)

  service Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
}

model Designation {
  id           String @id @default(cuid())
  companyId    String
  departmentId String
  name         String

  company    Company    @relation(fields: [companyId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@unique([companyId, departmentId, name])
  @@index([companyId])
  @@index([departmentId])
}

model WorkShift {
  id           String @id @default(cuid())
  companyId    String
  name         String
  startTime    String // "09:00" local to company tz
  endTime      String // "18:00"
  graceMinutes Int    @default(0) // minutes after start still counted as on-time

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@index([companyId])
}

// ============================================================
// AUTH + RBAC (Module 13)
// ============================================================

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String
  passwordHash String? // null until the invited user sets their password
  role         Role
  isActive     Boolean  @default(true)
  // Self-managed profile:
  nickname     String?
  avatarUrl    String? // image URL — real uploads land in Phase 2 file storage
  bio          String?
  // Invite / set-password flow:
  setupToken          String?   @unique
  setupTokenExpiresAt DateTime?
  // Exactly one of these is set depending on role:
  employeeId   String?  @unique // internal users
  clientId     String?          // CLIENT role -> portal scope
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())

  company       Company        @relation(fields: [companyId], references: [id])
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])
  notifications Notification[]
  extensionTokens ExtensionToken[]

  @@unique([companyId, email])
  @@index([companyId])
}

// Long-lived bearer tokens for the browser extension (and future API clients).
// The raw token is shown once at connect time; only its SHA-256 hash is stored.
// Also the backing store for "connected devices" + sign-out-everywhere.
model ExtensionToken {
  id         String    @id @default(cuid())
  companyId  String
  userId     String
  tokenHash  String    @unique // sha-256 hex of the raw token
  label      String // device label, e.g. "Chrome on Windows"
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime? // null = no hard expiry
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

// ============================================================
// EMPLOYEES (Module 2)
// ============================================================

model Employee {
  id              String           @id @default(cuid())
  companyId       String
  employeeCode    String
  fullName        String
  email           String
  phone           String?
  photoKey        String?
  dateOfBirth     DateTime?
  joiningDate     DateTime
  departmentId    String?
  serviceId       String?
  designationId   String?
  managerId       String? // self-referential reporting line
  workShiftId     String?
  locationId      String?
  employmentType  EmploymentType   @default(FULL_TIME)
  probationStatus ProbationStatus  @default(ON_PROBATION)
  probationMonths Int?
  workLocation    String?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company        Company           @relation(fields: [companyId], references: [id])
  department     Department?       @relation(fields: [departmentId], references: [id])
  service        Service?          @relation(fields: [serviceId], references: [id])
  designation    Designation?      @relation(fields: [designationId], references: [id])
  workShift      WorkShift?        @relation(fields: [workShiftId], references: [id])
  location       Location?         @relation(fields: [locationId], references: [id])
  manager        Employee?         @relation("Reports", fields: [managerId], references: [id])
  reports        Employee[]        @relation("Reports")
  taskAssignments  TaskAssignee[]
  primaryServices  ProjectService[]
  headedDepts    Department[]      @relation("DeptHead")
  user           User?

  documents      EmployeeDocument[]
  emergencyContacts EmergencyContact[]
  capacity       EmployeeCapacity?
  attendance     Attendance[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  timeEntries    TimeEntry[]
  tasks          Task[]            @relation("Assignee")
  salaryStructures SalaryStructure[]
  payslips       Payslip[]

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([managerId])
}

model EmployeeDocument {
  id         String          @id @default(cuid())
  employeeId String
  type       EmployeeDocType
  fileKey    String
  fileName   String
  uploadedAt DateTime        @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model EmergencyContact {
  id           String @id @default(cuid())
  employeeId   String
  name         String
  relationship String?
  phone        String

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

// ============================================================
// RESOURCE ALLOCATION (Module 4)
// ============================================================

model EmployeeCapacity {
  id            String @id @default(cuid())
  employeeId    String @unique
  dailyHours    Float  @default(8)
  weeklyHours   Float  @default(40)
  monthlyHours  Float  @default(160)

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============================================================
// PROJECTS & TASKS (Module 3)
// ============================================================

model Project {
  id          String        @id @default(cuid())
  companyId   String
  clientId    String?
  name        String
  description String?
  startDate   DateTime?
  dueDate     DateTime?
  priority    Priority      @default(MEDIUM)
  status      ProjectStatus @default(PLANNING)
  type        ProjectType   @default(ONE_TIME)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company      Company          @relation(fields: [companyId], references: [id])
  client       Client?          @relation(fields: [clientId], references: [id])
  services     ProjectService[]
  tasks        Task[]
  timeEntries  TimeEntry[]
  deliverables Deliverable[]
  kbArticles   KbArticle[]
  attachments  Attachment[]

  @@index([companyId])
  @@index([clientId])
}

model Task {
  id           String     @id @default(cuid())
  projectId    String
  parentTaskId String? // subtask
  name         String
  description  String?
  assigneeId   String? // deprecated; use assignees (TaskAssignee)
  serviceId    String?
  createdById  String? // userId of the creator — acts as the reviewer (A) in the review flow
  finalLink    String? // worker's submitted output / preview link (current submission)
  dueDate      DateTime?
  priority     Priority   @default(MEDIUM)
  status       TaskStatus @default(TODO)
  startedAt    DateTime? // first moved to In Progress
  completedAt  DateTime? // moved to Completed
  orderIndex   Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project      Project          @relation(fields: [projectId], references: [id])
  parent       Task?            @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks     Task[]           @relation("Subtasks")
  assignee     Employee?        @relation("Assignee", fields: [assigneeId], references: [id])
  service      Service?         @relation(fields: [serviceId], references: [id])
  assignees    TaskAssignee[]
  checklist    ChecklistItem[]
  comments     Comment[]
  attachments  Attachment[]
  timeEntries  TimeEntry[]
  timers       TaskTimer[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([serviceId])
}

// Which services a project uses, and the primary employee for each.
model ProjectService {
  id                String  @id @default(cuid())
  projectId         String
  serviceId         String
  primaryAssigneeId String?

  project         Project   @relation(fields: [projectId], references: [id])
  service         Service   @relation(fields: [serviceId], references: [id])
  primaryAssignee Employee? @relation(fields: [primaryAssigneeId], references: [id])
  checklist       ProjectServiceChecklistItem[]

  @@unique([projectId, serviceId])
  @@index([projectId])
}

// Per-project checklist for a service. Seeded from the service's default
// template when the service is added to the project, editable per project, and
// copied onto tasks created for this service within this project.
model ProjectServiceChecklistItem {
  id               String @id @default(cuid())
  projectServiceId String
  text             String
  orderIndex       Int    @default(0)

  projectService ProjectService @relation(fields: [projectServiceId], references: [id], onDelete: Cascade)

  @@index([projectServiceId])
}

// Many employees can work on one task.
model TaskAssignee {
  id         String @id @default(cuid())
  taskId     String
  employeeId String

  task     Task     @relation(fields: [taskId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([taskId, employeeId])
  @@index([taskId])
  @@index([employeeId])
}

// Live stopwatch state for one employee on one task. Pause banks elapsed into
// accumulatedSeconds and clears runStartedAt; resume sets runStartedAt again.
// Multiple rows per employee = concurrent timers. Deleted on stop, after the
// total is finalized into a TimeEntry (timesheet) row.
model TaskTimer {
  id                 String      @id @default(cuid())
  companyId          String
  taskId             String
  userId             String // who is tracking time — any user (worker or reviewer)
  status             TimerStatus @default(RUNNING)
  accumulatedSeconds Int         @default(0)
  runStartedAt       DateTime? // set while RUNNING; null while PAUSED
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  task Task @relation(fields: [taskId], references: [id])

  @@unique([taskId, userId])
  @@index([companyId, userId])
  @@index([taskId])
}

model ChecklistItem {
  id        String  @id @default(cuid())
  taskId    String
  text      String
  isDone    Boolean @default(false)
  orderIndex Int    @default(0)

  task Task @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model Comment {
  id         String   @id @default(cuid())
  taskId     String
  authorId   String // userId
  body       String
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

// Polymorphic attachment: belongs to a task (extendable to project/deliverable later)
model Attachment {
  id         String   @id @default(cuid())
  taskId     String?
  projectId  String?
  announcementId String?
  fileKey    String
  fileName   String
  mimeType   String?
  sizeBytes  Int?
  uploadedBy String // userId
  createdAt  DateTime @default(now())

  task    Task?    @relation(fields: [taskId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  announcement Announcement? @relation(fields: [announcementId], references: [id])

  @@index([taskId])
  @@index([projectId])
  @@index([announcementId])
}

// ============================================================
// ATTENDANCE (Module 5)
// ============================================================

model Attendance {
  id             String         @id @default(cuid())
  companyId      String
  employeeId     String
  date           DateTime       @db.Date
  type           AttendanceType @default(PRESENT)
  markedManually Boolean        @default(false) // admin override wins over auto leave status
  clockIn        DateTime?
  clockOut       DateTime?
  location       String?
  createdAt      DateTime       @default(now())

  employee Employee        @relation(fields: [employeeId], references: [id])
  breaks   AttendanceBreak[]

  @@unique([employeeId, date])
  @@index([companyId, date])
}

model AttendanceBreak {
  id           String    @id @default(cuid())
  attendanceId String
  breakStart   DateTime
  breakEnd     DateTime?

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  @@index([attendanceId])
}

// ============================================================
// LEAVE (Module 6)
// ============================================================

model LeaveType {
  id              String          @id @default(cuid())
  companyId       String
  name            String // Casual, Sick, Paid, Unpaid
  description     String?
  paidType        LeavePaidType   @default(PAID)
  allowanceValue  Float           @default(0) // days granted per period (ignored when unlimited)
  allowancePeriod AllowancePeriod @default(YEAR)
  unlimited       Boolean         @default(false) // no fixed day count — apply freely (e.g. unpaid)
  annualQuota     Float           @default(0) // deprecated; kept for back-compat

  company   Company        @relation(fields: [companyId], references: [id])
  requests  LeaveRequest[]
  balances  LeaveBalance[]

  @@unique([companyId, name])
  @@index([companyId])
}

model LeaveBalance {
  id           String @id @default(cuid())
  employeeId   String
  leaveTypeId  String
  year         Int
  total        Float
  used         Float  @default(0)

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id              String         @id @default(cuid())
  companyId       String
  employeeId      String
  kind            RequestKind    @default(LEAVE)
  leaveTypeId     String? // null for WFH requests
  startDate       DateTime       @db.Date
  endDate         DateTime       @db.Date
  days            Float
  isHalfDay       Boolean        @default(false)
  reason          String?
  status          ApprovalStatus @default(PENDING)
  managerApprovedById String?
  hrApprovedById  String?
  decidedAt       DateTime?
  // A proposed-but-unapproved change (startDate/endDate/leaveTypeId/isHalfDay/days/reason).
  // The live request is untouched until an approver applies it. Null = no pending edit.
  pendingEdit     Json?
  editRequestedAt DateTime?
  createdAt       DateTime       @default(now())

  employee  Employee   @relation(fields: [employeeId], references: [id])
  leaveType LeaveType? @relation(fields: [leaveTypeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
}

// ============================================================
// TIMESHEET (Module 7)
// ============================================================

model TimeEntry {
  id            String         @id @default(cuid())
  companyId     String
  userId        String? // who tracked it — any user (incl. non-employee reviewers)
  employeeId    String? // set when that user is also an employee (for the timesheet)
  projectId     String
  taskId        String?
  date          DateTime       @db.Date
  hours         Float
  notes         String?
  status        ApprovalStatus @default(PENDING)
  approvedById  String?
  createdAt     DateTime       @default(now())

  employee Employee? @relation(fields: [employeeId], references: [id])
  project  Project   @relation(fields: [projectId], references: [id])
  task     Task?     @relation(fields: [taskId], references: [id])

  @@index([companyId])
  @@index([employeeId, date])
  @@index([userId])
}

// ============================================================
// PAYROLL (Module 8) — India statutory. Money in paise (Int).
// ============================================================

model SalaryStructure {
  id                String   @id @default(cuid())
  employeeId        String
  effectiveFrom     DateTime @db.Date
  // Earnings (monthly, in paise)
  basic             Int
  hra               Int      @default(0)
  specialAllowance  Int      @default(0)
  // Fixed recurring components; variable ones (bonus/incentive) entered per run
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model PayrollRun {
  id              String           @id @default(cuid())
  companyId       String
  periodYear      Int
  periodMonth     Int // 1-12
  status          PayrollRunStatus @default(DRAFT)
  totalCostPaise  Int              @default(0)
  processedCount  Int              @default(0)
  lockedAt        DateTime?
  createdAt       DateTime         @default(now())

  company  Company   @relation(fields: [companyId], references: [id])
  payslips Payslip[]

  @@unique([companyId, periodYear, periodMonth])
  @@index([companyId])
}

model Payslip {
  id            String   @id @default(cuid())
  payrollRunId  String
  employeeId    String
  // Frozen snapshots so historical payslips never change on recompute:
  earnings      Json // [{ code, label, amountPaise }]
  deductions    Json // [{ code, label, amountPaise }] incl. PF/ESI/PT
  grossPaise    Int
  totalDeductionPaise Int
  netPaise      Int
  ratesSnapshot Json // PF%, ESI%, PT slab applied
  pdfKey        String?
  createdAt     DateTime @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

// Professional Tax is state-specific slab data, kept as config (not hardcoded).
model ProfessionalTaxSlab {
  id            String @id @default(cuid())
  companyId     String
  state         String
  minGrossPaise Int
  maxGrossPaise Int? // null = no upper bound
  taxPaise      Int

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, state])
}

// ============================================================
// CLIENTS & PORTAL (Modules 9 & 10)
// ============================================================

model Client {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  companyName String?
  email       String?
  phone       String?
  address     String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  company  Company         @relation(fields: [companyId], references: [id])
  contacts ClientContact[]
  projects Project[]
  users    User[] // CLIENT-role portal logins

  @@index([companyId])
}

model ClientContact {
  id       String @id @default(cuid())
  clientId String
  name     String
  email    String?
  phone    String?

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Deliverable {
  id            String            @id @default(cuid())
  projectId     String
  name          String
  description   String?           // short context shown to the client
  link          String?           // deliverable URL (link-based review); fileKey reserved for Phase 2 uploads
  fileKey       String?
  status        DeliverableStatus @default(SUBMITTED)
  feedback      String?           // client's revision feedback
  submittedById String?           // internal user who published it
  decidedById   String?           // client user who approved / requested revision
  submittedAt   DateTime          @default(now())
  decidedAt     DateTime?

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

// ============================================================
// KNOWLEDGE BASE (Module 11)
// ============================================================

model KbCategory {
  id        String @id @default(cuid())
  companyId String
  name      String

  company  Company     @relation(fields: [companyId], references: [id])
  articles KbArticle[]

  @@unique([companyId, name])
  @@index([companyId])
}

model KbArticle {
  id           String   @id @default(cuid())
  companyId    String
  categoryId   String? // legacy / optional grouping
  projectId    String? // the project whose SOP this guide documents (SOPs differ per project)
  departmentId String? // organised by department…
  serviceId    String? // …and service (drives the "related guide" link on tasks)
  title        String
  body         String // markdown (empty for external-link articles)
  externalUrl  String? // when set, this is an external-link article (opens in a new tab)
  keywords     String?
  authorId     String // userId — original creator
  updatedById  String? // userId — last editor
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   KbCategory?        @relation(fields: [categoryId], references: [id])
  project    Project?           @relation(fields: [projectId], references: [id])
  department Department?        @relation(fields: [departmentId], references: [id])
  service    Service?           @relation(fields: [serviceId], references: [id])
  versions   KbArticleVersion[]

  @@index([companyId])
  @@index([projectId])
  @@index([departmentId])
  @@index([serviceId])
}

model KbArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  title     String
  body      String
  editorId  String // userId
  createdAt DateTime @default(now())

  article KbArticle @relation(fields: [articleId], references: [id])

  @@index([articleId])
}

// ============================================================
// NOTIFICATIONS (cross-cutting)
// ============================================================

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      String // TASK_ASSIGNED, LEAVE_APPROVED, PAYROLL_GENERATED, ...
  title     String
  body      String?
  channel   NotificationChannel @default(IN_APP)
  isRead    Boolean             @default(false)
  meta      Json? // entity ids for deep-linking
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

// ============================================================
// ACTIVITY LOG (generalized task activity timeline)
// ============================================================

model ActivityLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String // userId
  entityType String // "TASK", "PROJECT", "LEAVE_REQUEST", ...
  entityId   String
  action     String // "CREATED", "STATUS_CHANGED", ...
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([companyId, entityType, entityId])
}
